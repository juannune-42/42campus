#include "ft_printf.h"
#include <stdio.h>
#include <stdlib.h>

int	main(int argc, char **argv)
{
	if (argc > 1)
	{
		printf(" %p %p \n", (void *)0, (void *)0);
		printf("\n");
		ft_printf(" %p %p \n", 0, 0);
		printf("\n");
		printf(" NULL %s NULL \n", (char *)NULL);
		printf("\n");
		ft_printf(" NULL %s NULL \n", (char *)NULL);
		printf("\n");
		printf(argv[1], argv[2]);
		printf("\n");
		ft_printf(argv[1], argv[2]);
	}
	return (0);
}
